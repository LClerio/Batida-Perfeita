@model ChangePasswordViewModel

<div class="row justify-content-center mt-4">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card shadow-sm border-0 bg-body rounded-3">
            <div class="card-body p-4 p-md-5">

                <div class="mb-4">
                    <h2 class="h4 fw-bold text-dark mb-1">Alterar Senha</h2>
                    <p class="text-muted small">Para garantir a segurança da sua conta, escolha uma senha forte e que não utilize em outros sites.</p>
                </div>

                <form asp-controller="Account" asp-action="ChangePassword" method="post" role="form" novalidate>

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small p-2 mb-4" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="CurrentPassword" type="password" class="form-control border-2 bg-light-subtle focus-ring" placeholder="Senha Atual" autocomplete="current-password" required />
                        <label asp-for="CurrentPassword" class="text-secondary">Senha Atual</label>
                        <span asp-validation-for="CurrentPassword" class="invalid-feedback d-block mt-1 small fw-medium"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="NewPassword" type="password" class="form-control border-2 bg-light-subtle focus-ring" placeholder="Nova Senha" autocomplete="new-password" required />
                        <label asp-for="NewPassword" class="text-secondary">Nova Senha</label>
                        <span asp-validation-for="NewPassword" class="invalid-feedback d-block mt-1 small fw-medium"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="ConfirmPassword" type="password" class="form-control border-2 bg-light-subtle focus-ring" placeholder="Confirmar Nova Senha" autocomplete="new-password" required />
                        <label asp-for="ConfirmPassword" class="text-secondary">Confirmar Nova Senha</label>
                        <span asp-validation-for="ConfirmPassword" class="invalid-feedback d-block mt-1 small fw-medium"></span>
                    </div>

                    <div class="d-flex flex-column flex-sm-row justify-content-end gap-2 pt-3 mt-4 border-top">
                        <a asp-action="Profile" class="btn btn-outline-secondary px-4 order-2 order-sm-1">
                            Cancelar
                        </a>
                        <button type="submit" class="btn btn-primary px-4 fw-semibold shadow-sm order-1 order-sm-2">
                            Alterar Senha
                        </button>
                    </div>

                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}