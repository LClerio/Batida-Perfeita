@model ProfileViewModel

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center pb-3 mb-4 border-bottom">
        <h1 class="fw-bold h2 text-dark m-0">Centro de Contas</h1>

        <div class="d-flex align-items-center bg-light border rounded-3 px-3 py-1 shadow-sm">
            <span class="text-muted small me-2">ID: ---------</span>
            <button type="button" class="btn btn-sm p-0 border-0 text-secondary" title="Copiar ID">
                <i class="bi bi-copy"></i>
            </button>
        </div>
    </div>

    <div class="row g-5">

        <nav class="col-md-4 col-lg-3">
            <div class="nav flex-column nav-pills gap-2">
                <a asp-controller="Account" asp-action="Profile" class="nav-link active bg-primary bg-opacity-10 text-primary fw-semibold px-3 py-2 rounded-3 d-flex align-items-center">
                    <i class="bi bi-person-circle me-3 fs-5"></i> Visão geral da conta
                </a>

                <a asp-controller="Account" asp-action="PersonalData" class="nav-link text-secondary fw-medium px-3 py-2 rounded-3 d-flex align-items-center hover-menu">
                    <i class="bi bi-card-list me-3 fs-5"></i> Informações pessoais
                </a>

                <a asp-controller="Account" asp-action="Security" class="nav-link text-secondary fw-medium px-3 py-2 rounded-3 d-flex align-items-center hover-menu">
                    <i class="bi bi-key me-3 fs-5"></i> Senha e segurança
                </a>
            </div>
        </nav>

        <main class="col-md-8 col-lg-9">

            <div class="cc-card">

                <div class="cc-card-header">
                    <h2 class="cc-card-title">@ViewBag.TituloCard</h2>

                    @if (ViewBag.AbaAtiva == "visao-geral")
                    {
                        <a asp-action="PersonalData" class="cc-link-gerenciamento">
                            Gerenciamento <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    }
                </div>

                @await Html.PartialAsync((string)ViewBag.PartialName, Model)

            </div>

        </main>

    </div>
</div>

<style>
    .hover-menu:hover {
        background-color: #f8f9fa;
        color: #212529 !important;
    }

    .card {
        max-width: 800px;
    }
</style>