@model ProfileViewModel

<div class="row justify-content-center mt-4">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card shadow-sm border-0 bg-body rounded-3">
            <div class="card-body p-4 p-md-5">

                <div class="mb-4">
                    <h2 class="h4 fw-bold text-dark mb-1">Alterar Endereço de E-mail</h2>
                    <p class="text-muted small">Insira o seu novo e-mail abaixo. Você receberá uma confirmação após salvar.</p>
                </div>

                <form asp-controller="Account" asp-action="ChangeEmail" method="post" role="form" novalidate>

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small p-2 mb-4" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Email" type="email" class="form-control border-2 bg-light-subtle focus-ring" placeholder="nome@exemplo.com" autocomplete="email" required />
                        <label asp-for="Email" class="text-secondary">Novo Endereço de E-mail</label>
                        <span asp-validation-for="Email" class="invalid-feedback d-block mt-1 small fw-medium"></span>
                    </div>

                    <div class="d-flex flex-column flex-sm-row justify-content-end gap-2 pt-3 mt-4 border-top">
                        <a asp-action="Profile" class="btn btn-outline-secondary px-4 order-2 order-sm-1">
                            Cancelar
                        </a>
                        <button type="submit" class="btn btn-primary px-4 fw-semibold shadow-sm order-1 order-sm-2">
                            Salvar Alterações
                        </button>
                    </div>

                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}