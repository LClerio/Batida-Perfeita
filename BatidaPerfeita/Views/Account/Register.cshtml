@model LoginViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="row g-0">
                    <div class="col-md-5 d-none d-md-block">
                        <img src="~/img/Register.png"
                             alt="Registrar Usuário"
                             class="img-fluid"
                             style="object-fit: cover;" />
                    </div>

                    <div class="col-md-7">
                        <div class="card-body p-4 p-lg-5">
                            <h3 class="fw-bold mb-4 text-primary">Criar Conta</h3>
                            <p class="text-muted mb-4">Cadastre-se para gerenciar seus pedidos.</p>

                            <form asp-controller="Account" asp-action="Register" method="post">
                                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                                <div class="form-floating mb-3">
                                    <input asp-for="UserName" class="form-control" placeholder="Nome de usuário" />
                                    <label asp-for="UserName">Nome de Usuário</label>
                                    <span asp-validation-for="UserName" class="text-danger small"></span>
                                </div>

                                <div class="form-floating mb-4">
                                    <input asp-for="Password" type="password" class="form-control" placeholder="Senha" />
                                    <label asp-for="Password">Senha</label>
                                    <span asp-validation-for="Password" class="text-danger small"></span>
                                </div>

                                <div class="d-grid">
                                    <button type="submit" class="btn btn-primary btn-lg shadow-sm">
                                        Registrar
                                    </button>
                                </div>

                                <div class="mt-3 text-center">
                                    <small class="text-muted">
                                        Já tem uma conta? <a asp-action="Login" class="text-decoration-none">Faça login</a>
                                    </small>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>