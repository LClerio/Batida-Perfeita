@model Category


<div class="col-sm-6 col-md-4 col-lg-3 mb-4">
    <a asp-controller="Product"
       asp-action="Index"
       asp-route-categoryName="@Model.Name"
       class="text-decoration-none text-dark">

        <div class="card text-center shadow-sm h-100 border-0 category-card">
            <div class="card-body d-flax align-items-center justify-content-center">
                <h6 class="fw-bold text-white m-0">
                    @Model.Name
                </h6>
            </div>
        </div>
    </a>
</div>