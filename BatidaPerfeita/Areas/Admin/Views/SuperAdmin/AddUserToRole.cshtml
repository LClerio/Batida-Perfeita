@model UserRoleViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-5">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <i class="bi bi-person-badge-fill text-primary" style="font-size: 3rem;"></i>
                        <h2 class="fw-bold text-dark mt-3">Atribuir Permissão</h2>
                        <p class="text-muted">Vincule um usuário a uma regra de acesso</p>
                    </div>

                    <form asp-controller="SuperAdmin" asp-action="AddUserToRole" method="post">
                        <hr class="mb-4" />

                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="UserName" class="form-control border-secondary-subtle" placeholder="Nome do usuário" />
                            <label asp-for="UserName">Nome de Usuário</label>
                            <span asp-validation-for="UserName" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="RoleName" class="form-control border-secondary-subtle" placeholder="Nome da Role" />
                            <label asp-for="RoleName">Nome da Role (ex: Admin)</label>
                            <span asp-validation-for="RoleName" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg shadow-sm">
                                <i class="bi bi-check-circle me-2"></i>Confirmar Atribuição
                            </button>
                            <a asp-area="Admin" asp-controller="SuperAdmin" asp-action="Index" class="btn btn-outline-secondary">
                                Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}