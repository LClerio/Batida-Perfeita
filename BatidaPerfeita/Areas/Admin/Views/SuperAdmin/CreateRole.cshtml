@model RoleViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-5">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <i class="bi bi-shield-lock-fill text-primary" style="font-size: 3rem;"></i>
                        <h2 class="fw-bold text-dark mt-3">Nova Regra</h2>
                        <p class="text-muted">Defina o nome da nova Role de acesso</p>
                    </div>

                    <form asp-controller="SuperAdmin" asp-action="CreateRole" method="post" role="form">
                        <hr class="mb-4" />
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="RoleName" class="form-control border-secondary-subtle" placeholder="Ex: Gerente" />
                            <label asp-for="RoleName">Nome da Role</label>
                            <span asp-validation-for="RoleName" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm">
                                <i class="bi bi-plus-circle me-2"></i>Criar Role
                            </button>
                            <a asp-action="Index" asp-controller="Admin" class="btn btn-outline-secondary">
                                Voltar ao Painel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}